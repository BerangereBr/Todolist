{
    "version": 2,
    "builds": [
        {
            "src": "api/app.js",
            "use": "@vercel/node",
            "config": {
                "runtime": "nodejs22.x"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/app.js"
        }
    ]
}